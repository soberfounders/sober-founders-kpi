# Runtime
APP_ENV=development
LOG_LEVEL=info

# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_APP_TOKEN=xapp-REPLACE_ME
# Optional in Socket Mode; required if you later switch to HTTP request mode
SLACK_SIGNING_SECRET=REPLACE_ME

# OpenAI
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4.1-mini

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
# Optional fallback keys for invoking edge functions
SUPABASE_ANON_KEY=
MASTER_SYNC_EDGE_INVOKE_KEY=

# Dashboard / links
DASHBOARD_BASE_URL=https://YOUR_DASHBOARD_URL

# Scheduler and limits
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_MS=60000
RATE_LIMIT_WINDOW_SEC=30
RATE_LIMIT_MAX_REQUESTS=5
CONFIRMATION_TTL_MINUTES=15

# Channel policies
# Comma-separated list of channel IDs treated as executive by default
SLACK_EXECUTIVE_CHANNELS=
HIGH_IMPACT_EXECUTIVE_CHANNELS=
# Comma-separated channels where plain messages trigger KPI replies (no @mention needed)
FREE_CHAT_CHANNEL_IDS=
DEFAULT_SUMMARY_CHANNEL=
