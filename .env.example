# -----------------------------------------------------------------------------
# Root Environment Template (server-side scripts + Supabase Edge Functions)
# -----------------------------------------------------------------------------
# Copy to `.env` for local use. Never commit real secrets.
#
# Environment model:
# - local: this file values (developer machine)
# - staging: set in Supabase/Vercel staging projects
# - production: set in Supabase/Vercel production projects
# Keep values isolated per environment; do not reuse production secrets locally.

# Supabase project/app auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database direct/pooler URL for integrity and ops scripts
SUPABASE_DB_URL=
DATABASE_URL=

# HubSpot sync
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_WEBHOOK_SECRET=
HUBSPOT_SYNC_ALERT_WEBHOOK_URL=

# Orchestration/auth for internal edge invocations
MASTER_SYNC_EDGE_INVOKE_KEY=

# Integrations
# Legacy Zoom credentials intentionally removed: attendance sync is HubSpot-call only.
NOTION_API_KEY=
NOTION_DATABASE_ID=
META_AD_ACCOUNT_ID=
META_AD_ACCOUNT_IDS=
ZEFFY_WEBHOOK_SECRET=
GA_PROPERTY_ID=
GA4_PROPERTY_ID=
GOOGLE_ANALYTICS_PROPERTY_ID=
GSC_SITE_URL=

# AI providers (edge functions)
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
CLAUDE_API_KEY=
SLACK_WEBHOOK_URL=

# Optional local script/test values
CI=false
USERPROFILE=
