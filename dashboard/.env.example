# -----------------------------------------------------------------------------
# Frontend Environment Template (Vite client variables)
# -----------------------------------------------------------------------------
# Copy to `dashboard/.env.local` for local development.
# These are bundled into client code. Do not place private server-only secrets
# here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Feature flags
VITE_ENABLE_REMOTE_AI_MODULE_ANALYSIS=false
VITE_USE_DUMMY_DONATIONS=false
VITE_ATTENDANCE_ENABLE_BAD_NAMES_QA=false

# Optional tuning (defaults in code shown at right)
VITE_DASHBOARD_LOOKBACK_DAYS=365
VITE_HUBSPOT_CONTACT_LOOKBACK_DAYS=365
VITE_LEADS_LOOKBACK_DAYS=365
VITE_LEADS_ATTRIBUTION_HISTORY_DAYS=120
VITE_ATTENDANCE_BACKFILL_DAYS=365

# Optional IDs
VITE_HUBSPOT_PORTAL_ID=45070276

# Optional client-side AI keys (prefer server-side edge functions)
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=
VITE_CLAUDE_API_KEY=
VITE_ANTHROPIC_API_KEY=
